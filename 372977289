local ESP_Table = {}
local function CreateESP(p)
    if p == player then return end
    local o = { Box = Drawing.new("Square"), HealthBar = Drawing.new("Square"), HealthText = Drawing.new("Text"), Name = Drawing.new("Text"), Distance = Drawing.new("Text"), Skeleton = {} }
    o.Box.Color, o.Box.Thickness, o.Box.Filled = Color3.fromRGB(255,0,0), 1.5, false
    o.HealthBar.Thickness, o.HealthBar.Filled = 1, true
    o.HealthText.Size, o.HealthText.Center, o.HealthText.Outline, o.HealthText.Color = 13, true, true, Color3.new(1,1,1)
    o.Name.Center, o.Name.Outline, o.Name.Size, o.Name.Color = true, true, 14, Color3.new(1,1,1)
    o.Distance.Center, o.Distance.Outline, o.Distance.Size, o.Distance.Color = true, true, 13, Color3.new(1,1,1)
    local bones = {"HeadToTorso", "TorsoToLeftArm", "TorsoToRightArm", "TorsoToLeftLeg", "TorsoToRightLeg"}
    for _, bone in pairs(bones) do local l = Drawing.new("Line") l.Thickness, l.Color, l.Visible = 2, Color3.new(1,1,1), false o.Skeleton[bone] = l end
    ESP_Table[p] = o
end
for _, p in pairs(Players:GetPlayers()) do CreateESP(p) end
Players.PlayerAdded:Connect(CreateESP)

RunService.RenderStepped:Connect(function(dt)
    FOVCircle.Position = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y/2)
    FOVCircle.Radius = _G.NS_SETTINGS.FOV
    
    local target, shortestDist = nil, _G.NS_SETTINGS.FOV
    for p, v in pairs(ESP_Table) do
        local char = p.Character
        if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Head") and char.Humanoid.Health > 0 then
            local hrp, hum, head = char.HumanoidRootPart, char.Humanoid, char.Head
            local pos, onScreen = camera:WorldToViewportPoint(hrp.Position)
            if onScreen and _G.NS_SETTINGS.ESPEnabled then
                local s = (1 / pos.Z) * 1000
                local w, h = 2.5*s, 4.5*s
                v.Box.Visible, v.Box.Size, v.Box.Position = true, Vector2.new(w, h), Vector2.new(pos.X - w/2, pos.Y - h/2)
                local hp = hum.Health / hum.MaxHealth
                v.HealthBar.Visible, v.HealthBar.Size, v.HealthBar.Position, v.HealthBar.Color = true, Vector2.new(2, h * hp), Vector2.new(pos.X - w/2 - 5, (pos.Y + h/2) - (h * hp)), Color3.fromHSV(hp * 0.3, 1, 1)
                v.HealthText.Visible, v.HealthText.Text, v.HealthText.Position = true, math.floor(hum.Health) .. " HP", Vector2.new(pos.X - w/2 - 25, pos.Y)
                v.Name.Visible, v.Name.Text, v.Name.Position = true, p.Name, Vector2.new(pos.X, pos.Y - h/2 - 18)
                v.Distance.Visible, v.Distance.Text, v.Distance.Position = true, math.floor((player.Character.HumanoidRootPart.Position - hrp.Position).Magnitude).."m", Vector2.new(pos.X, pos.Y + h/2 + 5)
                if _G.NS_SETTINGS.ESPSkeleton then
                    local function gV2(n) local pt = char:FindFirstChild(n) if pt then local v3, vs = camera:WorldToViewportPoint(pt.Position) return Vector2.new(v3.X, v3.Y), vs end return nil, false end
                    local h2, hv = gV2("Head") local t, tv = gV2("UpperTorso") or gV2("Torso") local la, lav = gV2("LeftArm") or gV2("LeftUpperArm") local ra, rav = gV2("RightArm") or gV2("RightUpperArm") local ll, llv = gV2("LeftLeg") or gV2("LeftUpperLeg") local rl, rlv = gV2("RightLeg") or gV2("RightUpperLeg")
                    local function draw(b, p1, p2, v1, v2) if v1 and v2 then v.Skeleton[b].From, v.Skeleton[b].To, v.Skeleton[b].Visible = p1, p2, true else v.Skeleton[b].Visible = false end end
                    draw("HeadToTorso", h2, t, hv, tv) draw("TorsoToLeftArm", t, la, tv, lav) draw("TorsoToRightArm", t, ra, tv, rav) draw("TorsoToLeftLeg", t, ll, tv, llv) draw("TorsoToRightLeg", t, rl, tv, rlv)
                else for _, l in pairs(v.Skeleton) do l.Visible = false end end
                local screenPos, visible = camera:WorldToViewportPoint(head.Position)
                local dist = (Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y/2) - Vector2.new(screenPos.X, screenPos.Y)).Magnitude
                if dist < shortestDist and IsVisible(head) then shortestDist, target = dist, p end
            else v.Box.Visible, v.HealthBar.Visible, v.HealthText.Visible, v.Name.Visible, v.Distance.Visible = false, false, false, false, false for _, l in pairs(v.Skeleton) do l.Visible = false end end
        else v.Box.Visible, v.HealthBar.Visible, v.HealthText.Visible, v.Name.Visible, v.Distance.Visible = false, false, false, false, false for _, l in pairs(v.Skeleton) do l.Visible = false end end
    end

    -- // STABILIZED LOCK (Universal for AR/Sniper/Handgun)
    if _G.NS_SETTINGS.Locking and target then
        local head = target.Character.Head
        local lookAtCFrame = CFrame.lookAt(camera.CFrame.Position, head.Position)
        -- Uses a lerp weight that avoids physics fight (shaking)
        camera.CFrame = camera.CFrame:Lerp(lookAtCFrame, _G.NS_SETTINGS.Smoothness)
        
        if _G.NS_SETTINGS.ESPTargetLine then
            local tP, tO = camera:WorldToViewportPoint(head.Position)
            TargetLine.From, TargetLine.To, TargetLine.Visible = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y/2), Vector2.new(tP.X, tP.Y), tO
        else TargetLine.Visible = false end
        if _G.NS_SETTINGS.HardLock and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            player.Character.HumanoidRootPart.CFrame = head.CFrame * CFrame.new(0, 0, 3)
        end
    else TargetLine.Visible = false end
end)

RunService.Heartbeat:Connect(function(dt)
    workspace.Gravity = _G.NS_SETTINGS.GravityValue 
    local char = player.Character
    local hrp, hum = char and char:FindFirstChild("HumanoidRootPart"), char and char:FindFirstChildOfClass("Humanoid")
    if hrp and hum then
        if _G.NS_SETTINGS.DownActive then hrp.Velocity = Vector3.new(hrp.Velocity.X, -_G.NS_SETTINGS.DropLimit, hrp.Velocity.Z) _G.NS_SETTINGS.DownActive = false end
        if _G.NS_SETTINGS.SpeedEnabled and hum.MoveDirection.Magnitude > 0 then hrp:PivotTo(hrp.CFrame + (hum.MoveDirection * (_G.NS_SETTINGS.MaxSpeed / 5) * dt)) end
    end
end)

UserInputService.JumpRequest:Connect(function()
    local char = player.Character local hrp, hum = char and char:FindFirstChild("HumanoidRootPart"), char and char:FindFirstChildOfClass("Humanoid")
    if hrp and hum and (_G.NS_SETTINGS.InfJump or _G.NS_SETTINGS.JumpBoostEnabled) then
        if _G.NS_SETTINGS.InfJump or (hum:GetState() == Enum.HumanoidStateType.Running or hum:GetState() == Enum.HumanoidStateType.Landed) then
            hrp.Velocity = Vector3.new(hrp.Velocity.X, _G.NS_SETTINGS.JumpBoostEnabled and _G.NS_SETTINGS.JumpPower or 50, hrp.Velocity.Z)
        end
    end
end)
